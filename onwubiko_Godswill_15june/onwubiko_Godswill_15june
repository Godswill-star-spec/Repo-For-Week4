whoisfindings() {
           echo "===========WHO IS FINDINGS==========="
           echo ""
           whoisRegistrar=$(whois "$TARGET" | grep -E -i "registrar:|creation Date:|name server:")
           echo "$whoisRegistrar"
}

whoisfindings


dnsfindings() {
    echo ""
    echo "========= DNS FINDINGS==========="
    
    # Fetching the Mail Server (MX) records
    echo "Mail Server (MX Records):"
    # '+short' cleans the output to show only the priority and mail server address
    mx_records=$(dig "$TARGET" MX +short )
    echo "$mx_records"
    
    # Fetching Email Security policies (TXT records containing SPF data)
    echo "Email Security (TXT/SPF Records):"
    txt_records=$(dig "$TARGET" TXT +short | grep -i "v=spf1")
    echo "$txt_records"
}

dnsfindings

